{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pego.local/schemas/compliance-review.schema.json",
  "title": "PEGO Compliance Review",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "schema_version",
    "decision",
    "subject",
    "authority",
    "constitutional_alignment",
    "goal_alignment",
    "constraint_fit",
    "evidence_quality",
    "risks",
    "reversibility",
    "privacy_impact",
    "dissent",
    "conditions",
    "review_date_or_stop_condition"
  ],
  "properties": {
    "artifact_type": {
      "const": "compliance_review"
    },
    "schema_version": {
      "type": "integer",
      "minimum": 1
    },
    "decision": {
      "enum": [
        "approve",
        "approve_with_constraints",
        "request_more_information",
        "downgrade",
        "escalate",
        "reject"
      ]
    },
    "subject": {
      "type": "string",
      "minLength": 1
    },
    "authority": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "requested",
        "approved"
      ],
      "properties": {
        "requested": {
          "$ref": "#/$defs/authority_level"
        },
        "approved": {
          "$ref": "#/$defs/authority_level"
        }
      }
    },
    "constitutional_alignment": {
      "type": "string",
      "minLength": 1
    },
    "goal_alignment": {
      "type": "string",
      "minLength": 1
    },
    "constraint_fit": {
      "type": "string",
      "minLength": 1
    },
    "evidence_quality": {
      "$ref": "#/$defs/evidence_quality_list"
    },
    "risks": {
      "$ref": "#/$defs/risk_list"
    },
    "reversibility": {
      "$ref": "#/$defs/reversibility"
    },
    "privacy_impact": {
      "$ref": "#/$defs/privacy_impact"
    },
    "dissent": {
      "type": "string",
      "minLength": 1
    },
    "conditions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "review_date_or_stop_condition": {
      "type": "string",
      "minLength": 1
    }
  },
  "$defs": {
    "authority_level": {
      "enum": [
        "level_0_observe",
        "level_1_recommend",
        "level_2_direct",
        "level_3_execute",
        "level_4_escalate"
      ]
    },
    "evidence_quality_list": {
      "type": "array",
      "minItems": 1,
      "items": {
        "enum": [
          "direct_telemetry",
          "financial_model_output",
          "human_report",
          "repeated_observed_pattern",
          "expert_source",
          "agent_inference",
          "speculation"
        ]
      }
    },
    "privacy_impact": {
      "enum": [
        "private_only",
        "safe_to_summarize",
        "requires_explicit_disclosure_approval",
        "blocked"
      ]
    },
    "reversibility": {
      "enum": [
        "easy_to_reverse",
        "reversible_with_cost",
        "hard_to_reverse",
        "irreversible"
      ]
    },
    "risk_list": {
      "type": "array",
      "items": {
        "enum": [
          "financial",
          "health",
          "relationship",
          "career",
          "legal",
          "tax",
          "privacy",
          "reputation",
          "time",
          "energy",
          "psychological",
          "opportunity_cost"
        ]
      }
    }
  }
}
