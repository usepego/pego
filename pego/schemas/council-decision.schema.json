{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pego.local/schemas/council-decision.schema.json",
  "title": "PEGO Council Decision",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "schema_version",
    "date",
    "decision_frame",
    "source_recommendations",
    "proposed_directive",
    "council_outcome",
    "rationale",
    "expected_benefit",
    "key_risks",
    "dissent",
    "required_handoffs",
    "governance_status",
    "stop_conditions",
    "next_action",
    "review"
  ],
  "properties": {
    "artifact_type": {
      "const": "council_decision"
    },
    "schema_version": {
      "type": "integer",
      "minimum": 1
    },
    "date": {
      "type": "string",
      "format": "date"
    },
    "decision_frame": {
      "type": "string",
      "minLength": 1
    },
    "source_recommendations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "proposed_directive": {
      "type": "string",
      "minLength": 1
    },
    "council_outcome": {
      "enum": [
        "adopt",
        "revise",
        "request_more_information",
        "escalate",
        "block"
      ]
    },
    "rationale": {
      "type": "string",
      "minLength": 1
    },
    "expected_benefit": {
      "type": "string"
    },
    "key_risks": {
      "type": "array",
      "items": {
        "enum": [
          "financial",
          "health",
          "relationship",
          "career",
          "legal",
          "tax",
          "privacy",
          "reputation",
          "time",
          "energy",
          "psychological",
          "opportunity_cost"
        ]
      }
    },
    "dissent": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "required_handoffs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "governance_status": {
      "type": "string",
      "minLength": 1
    },
    "stop_conditions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "next_action": {
      "type": "string",
      "minLength": 1
    },
    "review": {
      "type": "string",
      "minLength": 1
    }
  }
}
