{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pego.local/schemas/directive-outcome.schema.json",
  "title": "PEGO Directive Outcome",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "schema_version",
    "date",
    "source_directive",
    "directive_summary",
    "completion",
    "what_happened",
    "evidence",
    "friction",
    "benefit",
    "cost",
    "protected_time_impact",
    "stakeholder_impact",
    "environment_impact",
    "follow_up_directive_candidates",
    "agent_updates",
    "governance_notes",
    "next_review"
  ],
  "properties": {
    "artifact_type": {
      "const": "directive_outcome"
    },
    "schema_version": {
      "type": "integer",
      "minimum": 1
    },
    "date": {
      "type": "string",
      "format": "date"
    },
    "source_directive": {
      "type": "string",
      "minLength": 1
    },
    "directive_summary": {
      "type": "string",
      "minLength": 1
    },
    "completion": {
      "enum": [
        "completed",
        "partially_completed",
        "not_completed",
        "blocked",
        "canceled"
      ]
    },
    "what_happened": {
      "type": "string",
      "minLength": 1
    },
    "evidence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "enum": [
          "direct_observation",
          "human_report",
          "telemetry",
          "artifact_produced",
          "calendar_record",
          "financial_model_output",
          "other"
        ]
      }
    },
    "friction": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "benefit": {
      "type": "string"
    },
    "cost": {
      "type": "string"
    },
    "protected_time_impact": {
      "$ref": "#/$defs/impact"
    },
    "stakeholder_impact": {
      "type": "string"
    },
    "environment_impact": {
      "type": "string"
    },
    "follow_up_directive_candidates": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "agent_updates": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "governance_notes": {
      "type": "string"
    },
    "next_review": {
      "type": "string"
    }
  },
  "$defs": {
    "impact": {
      "enum": [
        "none",
        "low",
        "medium",
        "high"
      ]
    }
  }
}
