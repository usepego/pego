{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pego.local/schemas/monthly-strategy-review.schema.json",
  "title": "PEGO Monthly Strategy Review",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "schema_version",
    "month",
    "strategic_thesis",
    "outcome_summary",
    "decision_quality_summary",
    "agent_calibration_summary",
    "goal_progress_summary",
    "behavior_loop_summary",
    "scenario_benchmark_summary",
    "governance_review_items",
    "evidence_gathering_directives",
    "council_strategy_summary",
    "goal_progress",
    "agent_assessments",
    "assumptions_revisited",
    "strategy_changes",
    "decision_packets_needed",
    "constitution_concerns",
    "next_month_priorities",
    "stop_conditions"
  ],
  "properties": {
    "artifact_type": {
      "const": "monthly_strategy_review"
    },
    "schema_version": {
      "type": "integer",
      "minimum": 1
    },
    "month": {
      "type": "string",
      "minLength": 1
    },
    "strategic_thesis": {
      "type": "string",
      "minLength": 1
    },
    "outcome_summary": {
      "type": "string",
      "minLength": 1
    },
    "decision_quality_summary": {
      "$ref": "#/$defs/summary_object"
    },
    "agent_calibration_summary": {
      "$ref": "#/$defs/summary_object"
    },
    "goal_progress_summary": {
      "$ref": "#/$defs/summary_object"
    },
    "behavior_loop_summary": {
      "$ref": "#/$defs/summary_object"
    },
    "scenario_benchmark_summary": {
      "$ref": "#/$defs/summary_object"
    },
    "governance_review_items": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/governance_review_item"
      }
    },
    "evidence_gathering_directives": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/evidence_gathering_directive"
      }
    },
    "council_strategy_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "strategy_posture",
        "decision_quality",
        "agent_calibration",
        "goal_progress",
        "behavior_loops",
        "scenario_benchmarks",
        "council_use"
      ],
      "properties": {
        "strategy_posture": {
          "enum": [
            "hold_strategy_and_gather_evidence",
            "eligible_for_agent_strategy_review"
          ]
        },
        "decision_quality": {
          "type": "string"
        },
        "agent_calibration": {
          "type": "string"
        },
        "goal_progress": {
          "type": "string"
        },
        "behavior_loops": {
          "type": "string"
        },
        "scenario_benchmarks": {
          "type": "string"
        },
        "council_use": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "goal_progress": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "goal_id",
          "status",
          "evidence",
          "progress",
          "friction",
          "next_adjustment"
        ],
        "properties": {
          "goal_id": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "enum": [
              "advanced",
              "stable",
              "stalled",
              "regressed",
              "needs_review"
            ]
          },
          "evidence": {
            "type": "string"
          },
          "progress": {
            "type": "string"
          },
          "friction": {
            "type": "string"
          },
          "next_adjustment": {
            "type": "string"
          }
        }
      }
    },
    "agent_assessments": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "finance",
        "health",
        "career",
        "venture",
        "home_environment",
        "relationships",
        "exploration",
        "communications",
        "happiness",
        "operations",
        "governance"
      ],
      "properties": {
        "finance": {
          "$ref": "#/$defs/agent_assessment"
        },
        "health": {
          "$ref": "#/$defs/agent_assessment"
        },
        "career": {
          "$ref": "#/$defs/agent_assessment"
        },
        "venture": {
          "$ref": "#/$defs/agent_assessment"
        },
        "home_environment": {
          "$ref": "#/$defs/agent_assessment"
        },
        "relationships": {
          "$ref": "#/$defs/agent_assessment"
        },
        "exploration": {
          "$ref": "#/$defs/agent_assessment"
        },
        "communications": {
          "$ref": "#/$defs/agent_assessment"
        },
        "happiness": {
          "$ref": "#/$defs/agent_assessment"
        },
        "operations": {
          "$ref": "#/$defs/agent_assessment"
        },
        "governance": {
          "$ref": "#/$defs/agent_assessment"
        }
      }
    },
    "assumptions_revisited": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/assumption_review"
      }
    },
    "strategy_changes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "decision_packets_needed": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "constitution_concerns": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "next_month_priorities": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "stop_conditions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "$defs": {
    "summary_object": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "summary"
      ],
      "properties": {
        "summary": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "governance_review_item": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source",
        "severity",
        "item"
      ],
      "properties": {
        "source": {
          "type": "string",
          "minLength": 1
        },
        "severity": {
          "enum": [
            "low",
            "medium",
            "high"
          ]
        },
        "item": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "evidence_gathering_directive": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source",
        "directive",
        "reason"
      ],
      "properties": {
        "source": {
          "type": "string",
          "minLength": 1
        },
        "directive": {
          "type": "string",
          "minLength": 1
        },
        "reason": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "agent_assessment": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "what_learned",
        "continue",
        "stop",
        "change",
        "missing_evidence",
        "dissent"
      ],
      "properties": {
        "what_learned": {
          "type": "string"
        },
        "continue": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "stop": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "change": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "missing_evidence": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "dissent": {
          "type": "string"
        }
      }
    },
    "assumption_review": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "assumption",
        "status",
        "evidence",
        "next_test"
      ],
      "properties": {
        "assumption": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "enum": [
            "supported",
            "weakened",
            "wrong",
            "unknown"
          ]
        },
        "evidence": {
          "type": "string"
        },
        "next_test": {
          "type": "string"
        }
      }
    }
  }
}
