{
  "version": 1,
  "name": "PEGO",
  "full_name": "Personal Executive Governance OS",
  "description": "A privacy-preserving framework for agent-governed personal strategy, directives, and compliance review.",
  "privacy": {
    "tracked_private_files": [
      "private/README.md"
    ],
    "private_instance_root": "private/",
    "protected_private_roots": [
      "private/",
      "private/_local/"
    ],
    "rule": "Framework files must not contain private subject facts, financial details, health details, relationship context, or local directive outputs."
  },
  "agents": [
    {
      "id": "council",
      "name": "Council Protocol",
      "protocol": "pego/agents/council-protocol.md",
      "default_authority": "Level 1: Recommend",
      "purpose": "Coordinate multi-agent deliberation and dissent."
    },
    {
      "id": "governance",
      "name": "Governance Agent",
      "protocol": "pego/agents/governance-agent.md",
      "default_authority": "Level 4: Escalate",
      "purpose": "Evaluate authority, privacy, risk, reversibility, and constitutional fit."
    },
    {
      "id": "finance",
      "name": "Finance Agent",
      "protocol": "pego/agents/finance-agent.md",
      "model_spec": "pego/finance/model-spec.md",
      "default_authority": "Level 1: Recommend",
      "purpose": "Model financial freedom paths, capital allocation proposals, runway, and tradeoffs."
    },
    {
      "id": "health",
      "name": "Health Agent",
      "protocol": "pego/agents/health-agent.md",
      "model_spec": "pego/health/model-spec.md",
      "default_authority": "Level 1: Recommend",
      "purpose": "Translate health goals into safe, low-friction food, movement, sleep, and recovery directives."
    },
    {
      "id": "career",
      "name": "Career Agent",
      "protocol": "pego/agents/career-agent.md",
      "model_spec": "pego/career/model-spec.md",
      "default_authority": "Level 1: Recommend",
      "purpose": "Evaluate work, venture, skill, network, and income strategies."
    },
    {
      "id": "venture",
      "name": "Venture Agent",
      "protocol": "pego/agents/venture-agent.md",
      "default_authority": "Level 1: Recommend",
      "purpose": "Translate income and autonomy goals into business theses, experiments, resources, and scheduled venture work."
    },
    {
      "id": "home_environment",
      "name": "Home and Environment Agent",
      "protocol": "pego/agents/home-environment-agent.md",
      "default_authority": "Level 1: Recommend",
      "purpose": "Preserve home, yard, garden, repairs, supplies, beauty, serenity, and environmental happiness."
    },
    {
      "id": "relationships",
      "name": "Relationships Agent",
      "protocol": "pego/agents/relationships-agent.md",
      "default_authority": "Level 1: Recommend",
      "purpose": "Protect spouse/partner time, household peace, social connection, and stakeholder impact."
    },
    {
      "id": "exploration",
      "name": "Exploration Agent",
      "protocol": "pego/agents/exploration-agent.md",
      "default_authority": "Level 1: Recommend",
      "purpose": "Turn curiosity, learning, travel, culture, and experiments into disciplined life optionality."
    },
    {
      "id": "communications",
      "name": "Communications Agent",
      "protocol": "pego/agents/communications-agent.md",
      "default_authority": "Level 1: Recommend",
      "purpose": "Govern voice, taste, public writing, positioning, and opportunity-oriented communication."
    },
    {
      "id": "happiness",
      "name": "Happiness Agent",
      "protocol": "pego/agents/happiness-agent.md",
      "model_spec": "pego/happiness/model-spec.md",
      "default_authority": "Level 1: Recommend",
      "purpose": "Protect the actual objective function: happiness, meaning, relationships, energy, and desired lived experience."
    },
    {
      "id": "operations",
      "name": "Operations Agent",
      "protocol": "pego/agents/operations-agent.md",
      "default_authority": "Level 1: Recommend",
      "purpose": "Convert reviewed strategy into executable daily, weekly, and monthly operating plans."
    }
  ],
  "governance": {
    "constitution_template": "pego/templates/constitution.md",
    "authority_levels": "pego/governance/authority-levels.md",
    "compliance_review": "pego/governance/compliance-review.md",
    "conflict_resolution": "pego/governance/conflict-resolution.md",
    "private_data_policy": "pego/governance/private-data-policy.md",
    "repository_access_policy": "pego/governance/repository-access-policy.md",
    "required_review_for": [
      "financial execution",
      "medical or health-risking changes",
      "legal commitments",
      "career-impacting decisions",
      "relationship-impacting decisions",
      "privacy-impacting disclosure",
      "irreversible or hard-to-reverse actions"
    ]
  },
  "operations": [
    {
      "id": "local_pegoctl",
      "runner": "pegoctl",
      "procedure": "pego/operations/first-run.md",
      "writes_to": "delegates to selected operation",
      "privacy": "depends-on-delegated-operation"
    },
    {
      "id": "package_cli_surface",
      "runner": "src/usepego/cli.py",
      "procedure": "pego/architecture/distribution-installation.md",
      "writes_to": "delegates to selected operation",
      "privacy": "depends-on-delegated-operation"
    },
    {
      "id": "bootstrap_private_instance",
      "runner": "ops/private/bootstrap_private_instance.py",
      "procedure": "pego/operations/private-instance-workflow.md",
      "writes_to": "private/",
      "privacy": "protected-private-instance"
    },
    {
      "id": "check_private_instance_readiness",
      "runner": "ops/private/check_readiness.py",
      "procedure": "pego/operations/operating-readiness.md",
      "writes_to": "optional private/governance/preflight/readiness.json",
      "privacy": "safe-derived-output"
    },
    {
      "id": "check_private_storage_readiness",
      "runner": "ops/private/check_storage.py",
      "procedure": "pego/operations/private-storage-backup.md",
      "writes_to": "optional private/governance/preflight/storage-readiness.json",
      "privacy": "safe-derived-output"
    },
    {
      "id": "generate_first_run_intake",
      "runner": "ops/onboarding/generate_intake.py",
      "procedure": "pego/ux/first-run-experience.md",
      "writes_to": "private/onboarding/intake/",
      "privacy": "protected-private-instance"
    },
    {
      "id": "generate_public_writing_brief",
      "runner": "ops/communications/generate_public_writing_brief.py",
      "procedure": "pego/agents/communications-agent.md",
      "writes_to": "private/writing/briefs/; private/directives/candidates/",
      "privacy": "protected-private-instance"
    },
    {
      "id": "daily_cycle",
      "runner": "ops/cycles/daily_cycle.py",
      "procedure": "pego/operations/daily-loop.md",
      "writes_to": "private/health/check-ins/; private/finance/check-ins/; private/council/decisions/; private/directives/candidates/; private/directives/queues/; private/directives/command-responses/; private/governance/preflight/; private/outcomes/directives/; private/reviews/outcomes/; private/context/updates/",
      "privacy": "protected-private-instance"
    },
    {
      "id": "weekly_cycle",
      "runner": "ops/cycles/weekly_cycle.py",
      "procedure": "pego/operations/weekly-loop.md",
      "writes_to": "private/directives/weekly/",
      "privacy": "protected-private-instance"
    },
    {
      "id": "operator_next_step",
      "runner": "ops/operator/next_step.py",
      "procedure": "pego/operations/operator-interface.md",
      "writes_to": "private/directives/command-responses/; private/governance/preflight/",
      "privacy": "protected-private-instance"
    },
    {
      "id": "generate_operating_brief",
      "runner": "ops/operator/generate_brief.py",
      "procedure": "pego/operations/operator-interface.md",
      "writes_to": "private/operator/briefs/",
      "privacy": "protected-private-instance"
    },
    {
      "id": "close_user_session",
      "runner": "ops/operator/close_session.py",
      "procedure": "pego/operations/outcome-review.md",
      "writes_to": "private/reviews/sessions/",
      "privacy": "protected-private-instance"
    },
    {
      "id": "user_mode_check_in",
      "runner": "ops/operator/user_check_in.py",
      "procedure": "pego/operations/intra-day-command-loop.md",
      "writes_to": "private/operator/sessions/; private/directives/command-responses/; private/governance/preflight/",
      "privacy": "protected-private-instance"
    },
    {
      "id": "record_directive_outcome",
      "runner": "ops/outcomes/record_outcome.py",
      "procedure": "pego/operations/outcome-review.md",
      "writes_to": "private/outcomes/directives/; optionally private/directives/sessions/",
      "privacy": "protected-private-instance"
    },
    {
      "id": "review_directive_outcome",
      "runner": "ops/review/review_outcome.py",
      "procedure": "pego/operations/outcome-review.md",
      "writes_to": "private/reviews/outcomes/",
      "privacy": "protected-private-instance"
    },
    {
      "id": "record_context_update",
      "runner": "ops/context/record_context_update.py",
      "procedure": "pego/operations/context-update.md",
      "writes_to": "private/context/updates/; optionally private destination files",
      "privacy": "protected-private-instance"
    },
    {
      "id": "promote_session_review_context",
      "runner": "ops/context/promote_session_review.py",
      "procedure": "pego/operations/context-update.md",
      "writes_to": "private/context/updates/; private/context/promotions/",
      "privacy": "protected-private-instance"
    },
    {
      "id": "generate_daily_directive",
      "runner": "ops/directives/generate_daily_directive.py",
      "procedure": "pego/operations/directive-runner.md",
      "writes_to": "private/directives/daily/",
      "privacy": "protected-private-instance"
    },
    {
      "id": "select_next_directive",
      "runner": "ops/directives/next_directive.py",
      "procedure": "pego/operations/directive-runner.md",
      "writes_to": "private/directives/command-responses/",
      "privacy": "protected-private-instance"
    },
    {
      "id": "generate_anticipation_scan",
      "runner": "ops/anticipation/generate_scan.py",
      "procedure": "pego/operations/anticipation-loop.md",
      "writes_to": "private/anticipation/scans/",
      "privacy": "protected-private-instance"
    },
    {
      "id": "decide_attention",
      "runner": "ops/attention/decide_attention.py",
      "procedure": "pego/operations/attention-governance.md",
      "writes_to": "private/attention/decisions/; private/directives/candidates/",
      "privacy": "protected-private-instance"
    },
    {
      "id": "synthesize_directive_queue",
      "runner": "ops/synthesis/synthesize_queue.py",
      "procedure": "pego/operations/directive-synthesis.md",
      "writes_to": "private/directives/queues/",
      "privacy": "protected-private-instance"
    },
    {
      "id": "synthesize_council_decision",
      "runner": "ops/council/synthesize_decision.py",
      "procedure": "pego/agents/council-protocol.md",
      "writes_to": "private/council/decisions/",
      "privacy": "protected-private-instance"
    },
    {
      "id": "council_decision_to_candidate",
      "runner": "ops/council/decision_to_candidate.py",
      "procedure": "pego/operations/directive-synthesis.md",
      "writes_to": "private/directives/candidates/",
      "privacy": "protected-private-instance"
    },
    {
      "id": "generate_compliance_review",
      "runner": "ops/governance/generate_compliance_review.py",
      "procedure": "pego/operations/compliance-review-runner.md",
      "writes_to": "private/governance/reviews/",
      "privacy": "protected-private-instance"
    },
    {
      "id": "directive_preflight",
      "runner": "ops/governance/directive_preflight.py",
      "procedure": "pego/governance/compliance-review.md",
      "writes_to": null,
      "privacy": "safe-derived-output"
    },
    {
      "id": "run_finance_scenarios",
      "runner": "ops/finance/run_scenarios.py",
      "procedure": "ops/finance/README.md",
      "writes_to": "private/_local/finance/scenario-output.json; optionally private/finance/scenario-results.md",
      "privacy": "protected-private-instance"
    },
    {
      "id": "review_finance_scenarios",
      "runner": "ops/finance/review_scenarios.py",
      "procedure": "pego/finance/model-spec.md",
      "writes_to": "private/finance/reviews/",
      "privacy": "protected-private-instance"
    },
    {
      "id": "generate_finance_check_in",
      "runner": "ops/finance/generate_check_in.py",
      "procedure": "pego/finance/model-spec.md",
      "writes_to": "private/finance/check-ins/",
      "privacy": "protected-private-instance"
    },
    {
      "id": "generate_health_candidates",
      "runner": "ops/health/generate_candidates.py",
      "procedure": "pego/health/model-spec.md",
      "writes_to": "private/directives/candidates/health-candidates.md",
      "privacy": "protected-private-instance"
    },
    {
      "id": "generate_health_check_in",
      "runner": "ops/health/generate_check_in.py",
      "procedure": "pego/health/model-spec.md",
      "writes_to": "private/health/check-ins/",
      "privacy": "protected-private-instance"
    },
    {
      "id": "decide_meal",
      "runner": "ops/health/decide_meal.py",
      "procedure": "pego/health/food-environment-spec.md",
      "writes_to": "private/health/meal-decisions/; private/directives/candidates/",
      "privacy": "protected-private-instance"
    },
    {
      "id": "generate_home_candidates",
      "runner": "ops/home/generate_candidates.py",
      "procedure": "pego/agents/home-environment-agent.md",
      "writes_to": "private/directives/candidates/home-candidates.md",
      "privacy": "protected-private-instance"
    },
    {
      "id": "pego_doctor",
      "runner": "ops/pego_doctor.py",
      "procedure": "pego/operations/verification.md",
      "writes_to": null,
      "privacy": "safe"
    },
    {
      "id": "inspect_system_registry",
      "runner": "ops/pego_registry.py",
      "procedure": "pego/system/README.md",
      "writes_to": null,
      "privacy": "safe"
    }
  ],
